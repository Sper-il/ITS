{
  "version": "0.3.0",
  "configurations": [
    {
      "name": "🌐 Frontend (HTML - Live Server)",
      "type": "chrome",
      "request": "launch",
      "file": "${workspaceFolder}/frontend/index.html",
      "userDataDir": "${workspaceFolder}/.vscode/.chrome-user-data",
      "preLaunchTask": "echo Frontend: Open http://localhost:5500 or run Live Server",
      "webRoot": "${workspaceFolder}/frontend"
    },
    {
      "name": "🐍 Backend: FastAPI (uvicorn)",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": [
        "backend.api.main:app",
        "--reload",
        "--port",
        "8000",
        "--host",
        "0.0.0.0"
      ],
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      },
      "console": "integratedTerminal",
      "justMyCode": false
    },
    {
      "name": "🐍 Streamlit Dashboard (original app.py)",
      "type": "debugpy",
      "request": "launch",
      "module": "streamlit",
      "args": [
        "run",
        "TRAFFIC_PROCESSING/app.py",
        "--server.port",
        "8501",
        "--server.address",
        "0.0.0.0"
      ],
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      },
      "console": "integratedTerminal",
      "justMyCode": false
    },
    {
      "name": "🐍 All: Uvicorn + Streamlit (parallel)",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": [
        "backend.api.main:app",
        "--reload",
        "--port",
        "8000"
      ],
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      },
      "console": "integratedTerminal",
      "justMyCode": false,
      "presentation": {
        "group": "all",
        "order": 1
      }
    },
    {
      "name": "🔍 Debug Current File",
      "type": "debugpy",
      "request": "launch",
      "module": "python",
      "args": ["${file}"],
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      },
      "console": "integratedTerminal",
      "justMyCode": false
    }
  ],
  "compounds": [
    {
      "name": "🚀 Full Stack (API + Frontend)",
      "configurations": [
        "🐍 Backend: FastAPI (uvicorn)",
        "🌐 Frontend (HTML - Live Server)"
      ],
      "stopAll": true
    }
  ]
}
